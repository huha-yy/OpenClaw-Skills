# ============================================================
# OpenClaw 内容运营流水线 —— 环境变量配置
# ============================================================
# 用法: cp .env.example .env && vim .env
# .env 已在 .gitignore 中，不会提交到仓库
# ============================================================

# -------- 飞书（必填）--------
# App ID 和 Secret 从飞书开放平台获取: https://open.feishu.cn/app
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# 飞书群机器人 Webhook（用于 Cron 任务完成通知）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# 飞书个人 open_id（用于推送完成后的私聊通知，选填）
# FEISHU_NOTIFY_OPEN_ID=ou_xxx

# -------- DeepSeek（必填）--------
# 从 https://platform.deepseek.com/api_keys 获取
DEEPSEEK_API_KEY=sk-xxx

# -------- Pexels 图库（必填）--------
# 从 https://www.pexels.com/api/ 免费注册获取
PEXELS_API_KEY=xxx

# -------- ComfyUI（可选，不填则跳过 AI 生图）--------
# 如果部署了 ComfyUI，填写其地址；否则图片 pipeline 仅使用 Pexels
# COMFYUI_URL=http://127.0.0.1:8188
